# 환경변수 템플릿. 이 파일은 git 에 포함됨 — 비밀값 직접 입력 금지.
# 새 환경 셋업 시: cp .env.example .env  → 본인 값으로 채우기.

# Sentry 프로젝트 DSN. https://sentry.io 의 Settings → Client Keys (DSN) 에서 복사.
# EXPO_PUBLIC_ prefix 는 RN 클라이언트 번들에 노출됨 (DSN 은 공개 키라 OK).
EXPO_PUBLIC_SENTRY_DSN=

# ── Firebase Web SDK (PC 카운터 / 웹 빌드 전용) ────────────────────
# 네이티브(Android/iOS) 는 google-services.json / GoogleService-Info.plist 가
# 자동으로 init 하므로 아래 변수 불필요. 웹 빌드만 이걸로 init.
#
# 값 가져오는 곳: Firebase 콘솔 → 프로젝트 설정 → 내 앱 → 웹앱 → firebaseConfig
# 보안: API 키는 공개되어도 안전 (Firestore 규칙이 실제 권한 통제).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Azure Cognitive Services TTS (선택) ────────────────────────────
# 없으면 기기 내장 TTS 폴백. 있으면 자연스러운 신경망 목소리로 자동 교체.
# 가져오는 곳: portal.azure.com → Speech services → 키 및 엔드포인트 → 키 1
# 무료 (F0): 500,000자/월. 매장 규모 충분.
EXPO_PUBLIC_AZURE_TTS_KEY=
EXPO_PUBLIC_AZURE_TTS_REGION=koreacentral
EXPO_PUBLIC_AZURE_TTS_VOICE=ko-KR-SunHiNeural
