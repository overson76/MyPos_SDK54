// Firestore 보안 규칙 — Phase 6 에서 Firebase 콘솔에 배포.
// 매장(stores) 단위 격리. 멤버만 읽기/쓰기, 가입 요청은 누구나 만들 수 있되 본인 것만.
//
// 배포 방법:
//   1) Firebase 콘솔 → Firestore Database → 규칙 탭에 통째로 붙여넣기
//   2) 또는 Firebase CLI: `firebase deploy --only firestore:rules`
//
// 테스트:
//   콘솔의 "규칙 플레이그라운드" 에서 시뮬레이션 가능.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ─────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // 해당 매장의 멤버인가?
    function isMember(storeId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/stores/$(storeId)/members/$(uid()));
    }

    // 해당 매장의 대표(owner)인가?
    function isOwner(storeId) {
      return isMember(storeId)
        && get(/databases/$(database)/documents/stores/$(storeId)/members/$(uid())).data.role == 'owner';
    }

    // ── 매장 코드 → storeId 매핑 (가입 시 코드 검증용) ───────
    // 가입 안 된 사용자도 매장 코드로 storeId 를 찾을 수 있어야 함.
    // 단, 매장 정보 자체는 storeCodes 에 노출하지 않음 — id 만.
    match /storeCodes/{code} {
      allow read: if isSignedIn();
      allow write: if false; // 클라이언트 직접 쓰기 금지 (매장 생성 트랜잭션에서만 처리)
    }

    // ── 매장 문서 ─────────────────────────────────────────────
    match /stores/{storeId} {
      // 매장 정보는 멤버만 읽기. 단 신규 가입자는 가입 요청 만들기 위해 읽기 필요.
      // 가입 요청 만들기 전에 매장 존재 여부 확인 — 멤버 여부와 무관하게 읽기 허용 (이름 등 민감정보 최소화).
      allow read: if isSignedIn();

      // 매장 생성: 인증된 사용자가 본인을 ownerId 로 박아 생성.
      // (실제로는 매장 코드 발급 + members 동시 생성이 트랜잭션 단위라 클라이언트에서 처리)
      allow create: if isSignedIn()
        && request.resource.data.ownerId == uid();

      // 매장 업데이트: 대표만. 코드/생성자는 변경 불가 (코드 회전은 별도 정책).
      allow update: if isOwner(storeId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.code == resource.data.code;

      // 매장 삭제: 대표만.
      allow delete: if isOwner(storeId);

      // ── 멤버 ────────────────────────────────────────────────
      match /members/{memberUid} {
        allow read: if isMember(storeId);
        // 본인 멤버 문서 생성: 매장 생성 직후 owner 자기 자신 등록 (트랜잭션).
        // 또는 대표가 직원 가입 요청 승인 시 그 직원의 멤버 문서 생성.
        allow create: if isSignedIn()
          && (memberUid == uid() && request.resource.data.role == 'owner') // 매장 생성 시 본인 owner 등록
          || (isOwner(storeId) && request.resource.data.role == 'staff');  // 대표가 직원 승인
        // 본인 displayName 변경, 또는 대표가 다른 멤버 제거.
        allow update: if memberUid == uid() || isOwner(storeId);
        allow delete: if isOwner(storeId) || memberUid == uid(); // 본인 탈퇴 가능
      }

      // ── 가입 요청 (대표 승인 대기) ──────────────────────────
      match /joinRequests/{requestUid} {
        // 본인 요청만 보기 + 대표는 모든 요청 보기.
        allow read: if requestUid == uid() || isOwner(storeId);
        // 본인 요청만 생성/취소.
        allow create: if isSignedIn() && requestUid == uid();
        allow delete: if requestUid == uid() || isOwner(storeId);
        // 업데이트 금지 (요청은 immutable, 승인은 members 생성으로 처리).
        allow update: if false;
      }

      // ── 운영 데이터: 멤버 누구나 읽기/쓰기 ──────────────────
      match /menu/{menuId} {
        allow read, write: if isMember(storeId);
      }
      match /orders/{tableId} {
        allow read, write: if isMember(storeId);
      }
      match /history/{historyId} {
        allow read, write: if isMember(storeId);
      }
      match /addresses/{addrKey} {
        allow read, write: if isMember(storeId);
      }
    }
  }
}
