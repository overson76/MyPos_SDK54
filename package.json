{
  "name": "mypos_sdk54",
  "version": "1.0.22",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "deploy:web": "bash scripts/deploy-web.sh",
    "electron": "electron electron/main.js",
    "electron:kiosk": "cross-env MYPOS_KIOSK=1 electron electron/main.js",
    "build:web": "npx expo export --platform web",
    "kis:build": "dotnet build electron/payment/bridge/KisPaymentBridge.csproj -c Release -p:Platform=x86",
    "kis:test": "echo {\"dryRun\":true} | electron/payment/bridge/bin/x86/Release/net48/KisPaymentBridge.exe",
    "electron:build": "npm run deploy:web && electron-builder --config electron/builder.config.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-clone-referenced-element|@react-navigation/.*|@unimodules/.*|sentry-expo|native-base|react-native-svg))"
    ]
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/firestore": "^24.0.0",
    "@sentry/react-native": "~7.2.0",
    "electron-updater": "^6.8.3",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "^55.0.13",
    "expo-crypto": "~15.0.8",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "firebase": "^12.12.1",
    "iconv-lite": "^0.6.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "sip": "^0.0.6"
  },
  "private": true,
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16"
  }
}
